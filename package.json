{
  "name": "social-media-backend",
  "version": "1.0.0",
  "description": "Backend for social media platform with universal accounts, PGP encryption, and geo-locked chat rooms",
  "main": "server.js",
  "scripts": {
    "build": "npm --prefix frontend install && CI=false npm --prefix frontend run build",
    "railway:build": "npm run build",
    "start": "NODE_OPTIONS=--no-deprecation node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "news:zip-index:import": "node services/zipLocationIndexImporter.js"
  },
  "keywords": [
    "social-media",
    "mern",
    "railway",
    "encryption",
    "real-time"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^6.0.0",
    "mongoose": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "node-geocoder": "^4.2.0",
    "rss-parser": "^3.13.0",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prettier": "^3.8.1",
    "supertest": "^6.3.3"
  },
  "dependencyNotes": {
    "multer": "Pinned to 1.x for compatibility; planned breaking upgrade path is multer@2.",
    "aws-sdk": "Removed as unused. If AWS integrations are reintroduced, use modular @aws-sdk/client-* v3 packages (not aws-sdk v2)."
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
