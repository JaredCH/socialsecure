# Railway production variables for service: socialsecure
# Paste into Railway -> socialsecure -> Variables (Raw Editor)
# IMPORTANT: Do not wrap values in quotes.

# Core runtime
NODE_ENV=production
PORT=5000
CLIENT_URL=https://socialsecure-production.up.railway.app
JWT_SECRET=change-this-in-production

# Database/cache
# If service names differ, replace mongodb/redis below with your actual Railway service names.
MONGODB_URI=${{mongodb.MONGO_URL}}
REDIS_URL=${{redis.REDIS_URL}}

# Email/Twilio (optional unless you enable those features)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Frontend API override (optional)
# Leave blank to use same-origin /api (recommended for single-service deploy).
REACT_APP_API_URL=
