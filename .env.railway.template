# Railway production variables for service: socialsecure
# Paste these into Railway -> socialsecure -> Variables (Raw Editor)
# IMPORTANT: Do not wrap values in quotes.

NODE_ENV=production
CLIENT_URL=https://socialsecure-production.up.railway.app
MONGODB_URI=${{mongodb.MONGO_URL}}
REDIS_URL=${{redis.REDIS_URL}}
SMTP_PORT=587
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# Optional (only if you use these integrations)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
